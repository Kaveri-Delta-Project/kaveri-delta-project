      <listPerson>
        <person xml:id="p_5">
          <persName type="preferred">Tryambakarāyamakhin</persName>
          <persName type="variant">Tryambakayajvan</persName>
          <persName type="variant">Tryaṃbakādhvarin</persName>
          <trait type="associate" key="p_6">
            <label>Śāhaji I (of Thanjavur)</label>
          </trait>
          <trait type="patron" key="p_9">
            <label>Ḍhuṇḍirāja Vyāsa</label>
          </trait>
          <trait type="son" key="p_13">
            <label>Gaṅgādharādhvarin (alias Kākoji)</label>
          </trait>
          <trait type="brother" key="p_12">
