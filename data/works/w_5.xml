        <fileDesc>
            <titleStmt>
                <title>Sanskrit Project – Work</title>
            </titleStmt>
            
            <publicationStmt>
                <p>Unpublished research data</p>
            </publicationStmt>
            
            <sourceDesc>
                <p>Born digital</p>
            </sourceDesc>
        </fileDesc>
    </teiHeader>
    
    <text>
        <body>
            
            <!-- EDIT BELOW THIS LINE ONLY -->
            <listBibl>
                <!-- Identifier for the work file -->
                <bibl xml:id="w_5">
                                        
                    <!-- Primary title of work -->
                    <title type="preferred">A Work</title>
                    
                    <!-- Optional variant(s) for name of work -->
                    <title type="variant">Alternative Name of work</title>
                    
                    <!-- External authority identifier for the work -->
                    <!-- Use Wikidata if an item exists for this work -->
                    <!-- If not found on Wikidata try Library of Congress -->
                    <!-- Enter only the identifier (e.g. Wikidata Q123456, Library of Congress n12345678), not the full URL --> 
                    <idno type="Wikidata">Q123456</idno>
                    <idno type="LCNAF">n12345678</idno>
                    
                    <!-- Associated person(s) for work -->
                    <!-- Must link to person file in persons directory via key -->
                    <!-- Editors should also have a role attribute with a Marc Relator code -->
                    <!-- Editors in this case include authors - given appropriate code -->
                    <!-- Full list of applicable codes provided for the project -->
                    <editor key="p_1" role="aut">Name of author</editor>
                    <editor key="p_2" role="edt">Name of associated person (editor)</editor>

                    
                    <!-- Place(s) of composition/publication for the work -->
                    <!-- Must link to place file in places directory via key -->
                    <pubPlace key="l_3">
                        <placeName>Name of associated location</placeName>
                    </pubPlace>
                    
                    <!-- Any notes of interest related to work -->
                    <note>Any notes on the work added in this section</note>
                </bibl>
            </listBibl>
        </body>
    </text>
    
